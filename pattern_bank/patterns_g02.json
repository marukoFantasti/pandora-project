  "schema_changelog": {
    "0.2": [
      "answer_structure を追加: 'single'(従来) | 'comparison'(求差用の二部構成)",
      "computed_slots を追加: 数値スロットから機械導出される派生スロット(winner等)。AIにも乱数にも触らせない",
      "attribute_pairs を shared_lexicon に追加: 求補用の部分-全体の属性対(赤い/青い等)",
      "inverse_thinking=true のパターンを初追加(増加の逆思考)。operation が表層の動詞と逆になる型"
    ],
    "0.3": [
      "step_count=2 の初実装: computed_slots で中間値(mid)を機械導出し、answer_template に2本の式を並べる",
      "answer_formula は最終答えのみを指す(採点・result_view 連携用の単一値を保証)",
      "intermediate_formulas を追加: 途中式の検算用に中間値の式も機械導出可能にする"
    ],
    "0.4": [
      "かけ算パターン4種を追加(1あたり×いくつ分・倍・かけ算+たし算2step・全体-かけ算2step)",
      "slot spec に 'choices' を追加(rangeの代わりに離散集合からサンプリング)",
      "unit_range_overrides を追加: 同一パターンを単元別のかけられる数制限で再利用(だん章対応)",
      "container_sets を shared_lexicon に追加: 入れ物+中身+助数詞+動詞の整合束",
      "かけ算の順序規約: かけられる数=1あたり量。answer_template の {n_per}×{n_count} 固定で構造保証"
    ],
    "0.5": [
      "quantity_slots を追加: 複名数(cm_mm, m_cm, L_dL, h_min)と時刻(clock)を最小単位の整数で内部表現",
      "表示整形は unit_system 別の整形関数がジェネレータ側で担当(0の下位単位は省略: 90mm→9cm)",
      "制約式は最小単位の整数で記述(繰り上がり有無=難易度の制御が整数演算で書ける)",
      "answer_unit_system を追加: 答えの整形方式の指定",
      "時計読み取り問題(図依存)と c47 アレイ図は SVG連携課題として対象外",
      "template_number_constants を追加: テンプレート文に含めてよい定数の明示宣言(『1つの』『2本の』等)。数値照合(欠陥7)は宣言済み定数のみ許可"
    ],
    "0.6": [
      "unit_range_overrides に constraints_replace を追加: 単元別に制約式をルール名単位で差し替え(c26の3けた対応)",
      "クローン系追加: 3口合併・増減混合(バス)・m/cm合併・かさ求残・時間換算逆方向",
      "actor_c スロット対応(3人の登場人物、重複なしサンプリング)"
    ]
  },
  "file_note": "patterns_g02_add_sub.json から改名。加減以外も含むため patterns_g02.json が正式名"
}
